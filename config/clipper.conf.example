# Example configuration for scripts/clip_webpages.sh (macOS).
# Copy to config/clipper.conf and edit, or run scripts/install.sh to have it generated.
# Keep values shell-quoted when paths or names contain spaces.

# Absolute path to the Obsidian vault to monitor.
VAULT_PATH="/absolute/path/to/your/Obsidian Vault"

# Optional: name of a macOS Shortcut (Shortcuts.app) that triggers the
# Obsidian Web Clipper extension. Leave empty to skip the Shortcut path
# entirely and use direct AppleScript keystroke as the primary method.
#
# Leaving this empty removes one manual setup step (no Shortcut to create
# by hand) but still requires macOS Accessibility permission on the first
# run for osascript to send keystrokes. Set to a Shortcut name only if you
# already have one built or want to reuse it across other tools.
SHORTCUT_NAME=""

# Relative path inside VAULT_PATH where the Obsidian Web Clipper extension
# saves Markdown files. When set, only this subdirectory is scanned for new
# or changed .md files instead of the entire vault. Match this to the
# extension's "Save to" folder. Leave empty to scan the whole vault.
CLIP_OUTPUT_DIR="Inbox/Clippings"

# Key combo bound to "Obsidian Web Clipper" at chrome://extensions/shortcuts.
# Must match Chrome exactly, otherwise the popup will not appear.
# Modifiers: Shift, Ctrl/Control, Alt/Option, Cmd/Meta. Case-insensitive.
CLIP_SHORTCUT="Shift+Option+S"

# When SHORTCUT_NAME is set, fail before opening Chrome if that Shortcut
# is not found. Ignored when SHORTCUT_NAME is empty (direct keystroke
# mode does not depend on Shortcuts.app).
CHECK_SHORTCUT_EXISTS=1

# Timing knobs (seconds).
PAGE_LOAD_TIMEOUT=45
RENDER_GRACE_SECONDS=3
CLIP_TIMEOUT=30
MAX_RETRIES=3
POLL_INTERVAL=1

# Post-load login-wall detection (macOS, AppleScript-based).
# 1 = probe DOM/URL/text for login or paywall pages before triggering the
#     clipper. If detected, the script aborts this URL and logs
#     SUSPECTED_LOGIN_WALL instead of producing an empty note.
# 0 = skip the probe (behaves like the previous version).
#
# Requires: Chrome > View > Developer > "Allow JavaScript from Apple
# Events" enabled once. Without it, the probe logs a hint and continues.
LOGIN_WALL_CHECK=1
# Body text shorter than this + a weak signal is treated as suspicious.
LOGIN_WALL_MIN_TEXT=300
