# Example Windows configuration for scripts/clip_webpages.ps1.
# Copy to clipper.win.conf and edit, or run scripts/install.ps1 to generate one.

# Absolute path to the Obsidian vault. Use forward or back slashes.
VAULT_PATH="C:\Users\me\Documents\Obsidian Vault"

# Relative folder inside the vault where the Web Clipper saves notes.
# Leave empty to scan the whole vault.
CLIP_OUTPUT_DIR="Inbox/Clippings"

# REQUIRED, no default. The key combo you bound for "Quick clip" under
# "Obsidian Web Clipper" at chrome://extensions/shortcuts. Must match Chrome
# exactly, otherwise the popup will not appear. It cannot be auto-detected,
# so you must set it yourself (scripts/install.ps1 will ask for it).
# Modifiers: Shift, Ctrl/Control, Alt/Option, Cmd/Meta. Case-insensitive.
# Example: Shift+Alt+O
CLIP_SHORTCUT=""

# Trigger driver: ahk (AutoHotkey v2) or sendkeys.
TRIGGER_DRIVER=ahk
AHK_EXE=AutoHotkey64.exe

# Chrome bootstrap. Leave CHROME_EXE empty to auto-detect Program Files paths.
CHROME_EXE=
CHROME_DEBUG_PORT=9222
# Optional dedicated profile; if empty a per-user profile is created under LocalAppData.
CHROME_USER_DATA_DIR=

# Timing knobs (seconds). Same semantics as the macOS config.
PAGE_LOAD_TIMEOUT=45
RENDER_GRACE_SECONDS=3
CLIP_TIMEOUT=30
MAX_RETRIES=3
POLL_INTERVAL=1

# Post-load login-wall detection (Windows-only, CDP-based).
# 1 = probe DOM/URL/text for login or paywall pages before triggering the
#     clipper. If detected, the script aborts this URL and logs
#     SUSPECTED_LOGIN_WALL instead of producing an empty note.
# 0 = skip the probe (behaves like the previous version).
LOGIN_WALL_CHECK=1
# Body text shorter than this + a weak signal is treated as suspicious.
LOGIN_WALL_MIN_TEXT=300
